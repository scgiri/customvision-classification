# ─────────────────────────────────────────────────────────────
# Azure Custom Vision – Prediction credentials
# Copy this file to .env and fill in your values.
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────

CV_PREDICTION_KEY="<your-prediction-key>"
CV_PREDICTION_ENDPOINT="https://<your-resource>-prediction.cognitiveservices.azure.com/"
CV_PROJECT_ID="<your-project-guid>"
CV_PUBLISH_ITERATION_NAME="v1"
